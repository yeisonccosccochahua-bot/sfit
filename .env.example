# =============================================================================
# SFIT - Sistema de Fiscalización Inteligente de Transporte
# Variables de entorno - Copiar a .env y ajustar valores
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Base de Datos (PostgreSQL) ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sfit_db
DB_DATABASE=sfit_db
DB_USER=sfit_user
DB_USERNAME=sfit_user
DB_PASSWORD=sfit_pass_2026
DB_SYNCHRONIZE=true
DB_LOGGING=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=300

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_super_secret_jwt_key_in_production
JWT_EXPIRATION=7d
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change_this_super_secret_refresh_key_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Swagger ───────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_TITLE=SFIT API
SWAGGER_DESCRIPTION=Sistema de Fiscalización Inteligente de Transporte - API REST
SWAGGER_VERSION=1.0

# ── QR / Seguridad ────────────────────────────────────────────────────────────
# Clave HMAC para firmar/verificar QR codes de vehículos.
# ⚠️  CAMBIAR en producción — mínimo 32 caracteres aleatorios.
QR_HMAC_SECRET=sfit_qr_hmac_secret_change_in_production_min32chars
QR_BASE_URL=https://sfit.gob.pe/scan

# ── Email (SMTP / Nodemailer) ──────────────────────────────────────────────────
# Si no se configura, el servicio opera en modo mock (log a consola).
# Ejemplo Gmail: host=smtp.gmail.com, port=587, user=tu@gmail.com, pass=app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sfit.gob.pe
FROM_EMAIL=noreply@sfit.gob.pe

# ── WhatsApp Business API (Meta Cloud API) ─────────────────────────────────────
# Si no se configura, el servicio opera en modo mock (log a consola).
# Obtener en: https://developers.facebook.com/apps/{app_id}/whatsapp-business/
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_PHONE_ID=
WHATSAPP_TEMPLATE_NAME=sfit_alert
WHATSAPP_TEMPLATE_LANG=es

# ── Rate Limiting ──────────────────────────────────────────────────────────────
# Peticiones máximas por ventana de tiempo (ThrottlerModule).
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── Tests E2E ──────────────────────────────────────────────────────────────────
# Base de datos de pruebas. Puede ser la misma sfit_db o una separada.
# Se limpia al finalizar cada suite E2E.
DB_NAME_TEST=sfit_db

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3000
VITE_APP_NAME=SFIT
